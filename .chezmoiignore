.config/nushell/history.txt
.config/nvim/lazy-lock.json
.glaze-wm/errors.log
.glzr/glazewm/errors.log
.config/doublecmd/history.xml
.config/doublecmd/tabs.xml
.config/doublecmd/session.ini
.config/doublecmd/doublecmd.err
.config/doublecmd/doublecmd.inf
.config/doublecmd/ignorelist.txt

# zsh キャッシュと履歴
.config/zsh/.zcompdump*
.config/zsh/.zsh_history
.config/zsh/.zsh_sessions/
.config/zsh/zcompcache/
.config/zsh/.zcompcache/
.config/zsh/local-history
.config/zsh/history.local
.config/zsh/.histfile

# プラグインのキャッシュやgit情報
.config/zsh/plugins/**/.git/
.config/zsh/plugins/**/.gitignore
.config/zsh/plugins/**/cache/

# Claude Code — 動的ファイル（管理不要）
.claude.json
.claude/projects/
.claude/statsig/
.claude/cache/
.claude/history.jsonl
.claude/shell-snapshots/
.claude/session-env/

# rules 配下の local-* はこの環境固有の規範。chezmoi に取り込まずローカルに閉じる
.claude/rules/local-*.md

# リポジトリ用ドキュメント（target に展開しない。先頭 / でルート限定）
/CLAUDE.md

# バックアップと一時ファイル
.config/zsh/*~
.config/zsh/*.zwc
.config/zsh/.*.zwc
.config/zsh/*.old
.config/zsh/*.bak
.config/zsh/*.tmp

# Brewfile はプライベートな mac でのみ展開。業務端末は ~/.config/brewfile/Brewfile をローカル管理する
# （isPrivate 未定義の環境では安全側に倒して ignore。mac 以外は brew 非対象なので ignore）
{{ if or (not (dig "isPrivate" false .)) (ne .chezmoi.os "darwin") }}
.config/brewfile/Brewfile
{{ end }}

# AeroSpace 系一式 (タイル WM、JankyBorders、sketchybar、karabiner) はプライベートな mac でのみ展開
# 業務端末では karabiner/borders/sketchybar を別運用する余地があるので Brewfile と同条件で ignore
{{ if or (not (dig "isPrivate" false .)) (ne .chezmoi.os "darwin") }}
.config/aerospace
.config/sketchybar
.config/borders
.config/karabiner
{{ end }}

# karabiner-elements は backup を automatic_backups/ に大量に吐く。展開対象外
.config/karabiner/automatic_backups

# zebar は Windows の GlazeWM 用ステータスバーなので Windows でのみ展開
{{ if ne .chezmoi.os "windows" }}
.glzr/zebar
{{ end }}

# zebar 配下の動的ファイル・公式サンプル widget は管理対象外
.glzr/zebar/errors.log
.glzr/zebar/tmp-*
.glzr/zebar/boilerplate-*
.glzr/zebar/starter

# SSH — 頻繁に変化する known_hosts と除外対象の古い .pem は管理しない
.ssh/known_hosts
.ssh/known_hosts.old
.ssh/*.pem
.ssh/*.pem.pub

# config は personal infra のホストを含むため private 環境のみ展開
{{ if not (dig "isPrivate" false .) }}
.ssh/config
{{ end }}
