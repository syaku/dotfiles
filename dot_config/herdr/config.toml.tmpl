{{- /* chezmoi:template:line-endings=native */ -}}
onboarding = false

[terminal]
# 絶対パス指定にする。herdr server が `/usr/bin/login -flp ... bash --noprofile --norc`
# 経由で起動される経路では PATH に `/opt/homebrew/bin` が含まれず、`nu` だと
# "login shell 'nu' was not found on PATH" で workspace 作成に失敗する。
# macOS かつ isPrivate=false（会社支給機など）は、構成を共有しない素の zsh を既定にする。
{{- if eq .chezmoi.os "windows" }}
default_shell = "nu.exe"
{{- else if and (eq .chezmoi.os "darwin") (not (dig "isPrivate" false .)) }}
default_shell = "/bin/zsh"
{{- else }}
default_shell = "{{ lookPath "nu" }}"
{{- end }}
shell_mode = "auto"

[ui]
show_agent_labels_on_pane_borders = false

{{- if ne .chezmoi.os "windows" }}
[experimental]
# Kitty graphics protocol を pane に通す。外側ターミナル（ghostty 等）が
# kitty graphics をサポートしている前提で yazi 等の画像プレビューを復活させる。
# Windows では外側ターミナル側の挙動が不安定なため無効。
kitty_graphics = true
{{- end }}

[keys]
{{- if ne .chezmoi.os "windows" }}
# herdr の prefix キー（既定 ctrl+b を Mac の cmd+b に読み替え）
prefix = "cmd+b"
{{- end }}

# ── タブ操作（prefix-less ＋ prefix 経由を併存） ─────────────────────────
# array 構文で 1 アクションに 2 バインド：iTerm2 系の修飾キーと tmux 流派 prefix を両立。
# cheatsheet の「タブ補助」節（prefix + c/n/p/1-9/shift+x）が prefix-less と並行して効く。
{{- if eq .chezmoi.os "windows" }}
new_tab      = ["ctrl+t",       "prefix+c"]
close_tab    = ["ctrl+w",       "prefix+shift+x"]
next_tab     = ["ctrl+shift+]", "prefix+n"]
previous_tab = ["ctrl+shift+[", "prefix+p"]
switch_tab   = ["ctrl+1..9",    "prefix+1..9"]
{{- else }}
new_tab      = ["cmd+t",       "prefix+c"]
close_tab    = ["cmd+w",       "prefix+shift+x"]
next_tab     = ["cmd+shift+]", "prefix+n"]
previous_tab = ["cmd+shift+[", "prefix+p"]
switch_tab   = ["cmd+1..9",    "prefix+1..9"]
{{- end }}
rename_tab   = "prefix+,"   # tmux: rename-window 流派（既定 prefix+shift+t を上書き）

# ── ペイン操作（prefix 経由・tmux カスタム流派） ──────────────────────────
# 既定維持（明示しない）:
#   split_horizontal     = "prefix+minus"          （tmux カスタム流派と一致）
#   focus_pane_left/...  = "prefix+h/j/k/l"
#   swap_pane_left/...   = "prefix+shift+h/j/k/l"  （herdr 既定。--default-config 非掲載だが実在）
#   cycle_pane_previous  = "prefix+shift+tab"
#   close_pane           = "prefix+x"
#   zoom                 = "prefix+z"
#   resize_mode          = "prefix+r"
split_vertical  = "prefix+\\"   # tmux カスタム流派: | のキー位置 (\) で縦分割
cycle_pane_next = "prefix+o"    # tmux: select-pane（既定 prefix+tab から退避）
last_pane       = "prefix+;"    # tmux: last-pane（既定は未指定）

# ── セッション・その他 ───────────────────────────────────────────────────
# 既定維持（明示しない）:
#   toggle_sidebar = "prefix+b"   goto = "prefix+g"   new_worktree = "prefix+shift+g"
#   help = "prefix+?"
detach    = "prefix+d"    # tmux: detach-client 流派（既定 prefix+q を上書き）
copy_mode = "prefix+["    # tmux: copy-mode 流派

# prefix+o を cycle_pane_next に明け渡したので open_notification_target を退避
open_notification_target = "prefix+shift+o"

# ── エージェントフォーカス ───────────────────────────────────────────────
focus_agent = "prefix+alt+1..9"
