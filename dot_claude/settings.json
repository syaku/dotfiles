{
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_GIT_BASH_PATH": "C:\\Program Files\\Git\\bin\\bash.exe",
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "0"
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git remote *)",
      "Bash(git stash list)",
      "Bash(chezmoi diff)",
      "Bash(chezmoi diff *)",
      "Bash(chezmoi source-path)",
      "Bash(chezmoi source-path *)",
      "Bash(chezmoi status)",
      "Bash(chezmoi status *)",
      "Bash(chezmoi managed)",
      "Bash(chezmoi managed *)",
      "Bash(chezmoi ignored)",
      "Bash(chezmoi ignored *)",
      "Bash(chezmoi cat *)",
      "Bash(chezmoi data)",
      "Bash(chezmoi data *)",
      "Bash(chezmoi execute-template *)",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "WebFetch(domain:localhost)",
      "WebFetch(domain:127.0.0.1)",
      "WebFetch(domain:0.0.0.0)",
      "WebFetch(domain:169.254.169.254)",
      "WebFetch(domain:*.local)",
      "WebFetch(domain:*.internal)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git -C * push *)",
      "Bash(gh pr create *)"
    ],
    "defaultMode": "auto"
  },
  "model": "claude-opus-4-7[1m]",
  "cleanupPeriodDays": 30,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/chezmoi-source-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/format-on-edit.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '%s' '{\"terminalSequence\":\"\\u0007\"}'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "obsidian@obsidian-skills": true,
    "arscontexta@agenticnotetaking": true,
    "playwright@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    },
    "agenticnotetaking": {
      "source": {
        "source": "github",
        "repo": "agenticnotetaking/arscontexta"
      }
    }
  },
  "language": "日本語",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "preferredNotifChannel": "terminal_bell",
  "skipAutoPermissionPrompt": true
}
