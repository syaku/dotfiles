{
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(find *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(echo *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(wc *)",
      "Bash(diff *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(env)",
      "Bash(printenv *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git remote *)",
      "Bash(git stash list)",
      "Bash(chezmoi diff)",
      "Bash(chezmoi diff *)",
      "Bash(chezmoi source-path)",
      "Bash(chezmoi source-path *)",
      "Bash(chezmoi status)",
      "Bash(chezmoi status *)",
      "Bash(chezmoi managed)",
      "Bash(chezmoi managed *)",
      "Bash(chezmoi ignored)",
      "Bash(chezmoi ignored *)",
      "Bash(chezmoi cat *)",
      "Bash(chezmoi data)",
      "Bash(chezmoi data *)",
      "Bash(chezmoi execute-template *)",
      "Edit(~/workspace/tasks/**)",
      "Write(~/workspace/tasks/**)",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "WebFetch(domain:localhost)",
      "WebFetch(domain:127.0.0.1)",
      "WebFetch(domain:0.0.0.0)",
      "WebFetch(domain:169.254.169.254)",
      "WebFetch(domain:*.local)",
      "WebFetch(domain:*.internal)"{{ if .denyClaudeAiConnectors | default false }},
      "mcp__claude_ai_Gmail__*",
      "mcp__claude_ai_Google_Calendar__*",
      "mcp__claude_ai_Google_Drive__*"{{ end }}
    ],
    "defaultMode": "auto"
  },
  "model": "claude-opus-4-7",
  {{- /* enabledPlugins must stay present (even empty): per anthropics/claude-code#27247, plugin enables declared in a project's settings.local.json are silently ignored unless lower-priority user settings also define enabledPlugins. The slack plugin is enabled in ~/workspace/.claude/settings.local.json. */}}
  "enabledPlugins": {
    "obsidian@obsidian-skills": true
  },
  "extraKnownMarketplaces": {
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    }
  },
  "effortLevel": "xhigh",
  "skipAutoPermissionPrompt": true{{ if eq .chezmoi.os "windows" }},
  "env": {
    "CLAUDE_CODE_GIT_BASH_PATH": "C:\\Program Files\\Git\\bin\\bash.exe",
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "0"
  }{{ end }}
}
