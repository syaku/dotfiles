{
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"{{ if eq .chezmoi.os "windows" }},
    "CLAUDE_CODE_GIT_BASH_PATH": "C:\\Program Files\\Git\\bin\\bash.exe",
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "0"{{ end }}
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git remote *)",
      "Bash(git stash list)",
      "Bash(chezmoi diff)",
      "Bash(chezmoi diff *)",
      "Bash(chezmoi source-path)",
      "Bash(chezmoi source-path *)",
      "Bash(chezmoi status)",
      "Bash(chezmoi status *)",
      "Bash(chezmoi managed)",
      "Bash(chezmoi managed *)",
      "Bash(chezmoi ignored)",
      "Bash(chezmoi ignored *)",
      "Bash(chezmoi cat *)",
      "Bash(chezmoi data)",
      "Bash(chezmoi data *)",
      "Bash(chezmoi execute-template *)",
      "Edit(~/workspace/tasks/**)",
      "Write(~/workspace/tasks/**)",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "WebFetch(domain:localhost)",
      "WebFetch(domain:127.0.0.1)",
      "WebFetch(domain:0.0.0.0)",
      "WebFetch(domain:169.254.169.254)",
      "WebFetch(domain:*.local)",
      "WebFetch(domain:*.internal)"
    ],
    "defaultMode": "auto"
  },
  "model": "claude-opus-4-8",
  {{- /* enabledPlugins must stay present (even empty): per anthropics/claude-code#27247, plugin enables declared in a project's settings.local.json are silently ignored unless lower-priority user settings also define enabledPlugins. The slack plugin is enabled in ~/workspace/.claude/settings.local.json. */}}
  "enabledPlugins": {
    "obsidian@obsidian-skills": true
  },
  "extraKnownMarketplaces": {
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    }
  },
  "skipAutoPermissionPrompt": true{{- if or (eq .chezmoi.os "darwin") (eq .chezmoi.os "windows") }},
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            {{- if eq .chezmoi.os "darwin" }}
            "command": "osascript -e 'display notification \"確認待ちです\" with title \"Claude Code\" sound name \"Submarine\"'"
            {{- else if eq .chezmoi.os "windows" }}
            "command": "pwsh -NoProfile -WindowStyle Hidden -Command \"New-BurntToastNotification -Text 'Claude Code','確認待ちです'\""
            {{- end }}
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            {{- if eq .chezmoi.os "darwin" }}
            "command": "osascript -e 'display notification \"応答完了\" with title \"Claude Code\" sound name \"Glass\"'"
            {{- else if eq .chezmoi.os "windows" }}
            "command": "pwsh -NoProfile -WindowStyle Hidden -Command \"New-BurntToastNotification -Text 'Claude Code','応答完了'\""
            {{- end }}
          }
        ]
      }
    ]
  }
  {{- end }}
}
